{
  "name": "lck-teams-schedule",
  "version": "0.1.0",
  "description": "LCK 팬을 위한 팀별 일정 자동 동기화 .ics 피드 — 한 경기도 놓치지 않게",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "tsx src/main.ts",
    "view:ics": "tsx scripts/view-deployed.ts",
    "build": "tsc --noEmit && tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^7",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
